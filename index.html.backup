<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cotizaciones</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #1a1a1a;
    --white: #ffffff;
    --gray-light: #f5f5f5;
    --gray-border: #e0e0e0;
    --gray-text: #666666;
    --gold: #c9a96e;
    --gold-light: #f0e6d3;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', sans-serif;
    background: #e8e8e8;
    color: var(--black);
    min-height: 100vh;
  }

  /* Top toolbar */
  .toolbar {
    background: var(--black);
    color: var(--white);
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .toolbar h1 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 2px;
  }
  .toolbar-actions {
    display: flex;
    gap: 10px;
  }
  .toolbar-actions button {
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 8px 18px;
    border-radius: 4px;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .toolbar-actions button:hover {
    background: var(--white);
    color: var(--black);
  }
  .toolbar-actions button.primary {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--black);
    font-weight: 600;
  }
  .toolbar-actions button.primary:hover {
    background: #b8964e;
    border-color: #b8964e;
    color: var(--white);
  }
  .toolbar-actions button.danger {
    border-color: #e74c3c;
    color: #e74c3c;
  }
  .toolbar-actions button.danger:hover {
    background: #e74c3c;
    color: var(--white);
  }

  /* Page container */
  .page-wrapper {
    display: flex;
    justify-content: center;
    padding: 40px 20px;
  }
  .page {
    background: var(--white);
    width: 100%;
    max-width: 800px;
    min-height: 1100px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    position: relative;
    overflow: hidden;
  }

  /* Header */
  .header-banner {
    background: var(--black);
    padding: 40px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  .header-title {
    font-family: 'Great Vibes', cursive;
    font-size: 3.2rem;
    color: var(--white);
    font-weight: 400;
    letter-spacing: 1px;
  }
  .header-logo {
    text-align: right;
  }
  .logo-monogram {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
    letter-spacing: 4px;
  }
  .logo-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-top: 4px;
  }
  .logo-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.45rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 2px;
  }

  /* Editable fields */
  .editable {
    border: 1px dashed transparent;
    padding: 2px 6px;
    border-radius: 3px;
    outline: none;
    transition: all 0.2s;
    min-width: 60px;
    display: inline-block;
  }
  .editable:hover {
    border-color: var(--gray-border);
    background: var(--gray-light);
  }
  .editable:focus {
    border-color: var(--gold);
    background: var(--gold-light);
  }
  .header-banner .editable {
    color: var(--white);
  }
  .header-banner .editable:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.3);
  }
  .header-banner .editable:focus {
    background: rgba(255,255,255,0.15);
    border-color: var(--gold);
  }

  /* Client info */
  .client-info {
    padding: 32px 48px 16px;
    border-bottom: 1px solid var(--gray-border);
    display: flex;
    gap: 24px;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .client-info .field-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gray-text);
    margin-bottom: 2px;
  }
  .client-info .field-value {
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .client-info .editable {
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* Section */
  .section {
    padding: 0 48px;
    margin-top: 24px;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--black);
  }
  .section-header .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    flex: 1;
  }
  .section-header .editable {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
  }
  .section-header .remove-section {
    background: none;
    border: none;
    color: #ccc;
    cursor: pointer;
    font-size: 1.2rem;
    padding: 2px 6px;
    border-radius: 3px;
    transition: all 0.2s;
    display: none;
  }
  .section:hover .remove-section {
    display: block;
  }
  .section-header .remove-section:hover {
    color: #e74c3c;
    background: #fee;
  }

  /* Table */
  .item-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 4px;
  }
  .item-table thead th {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gray-text);
    font-weight: 500;
    padding: 8px 0;
    text-align: left;
  }
  .item-table thead th:nth-child(2),
  .item-table thead th:nth-child(3),
  .item-table thead th:nth-child(4),
  .item-table thead th:nth-child(5) {
    text-align: right;
    width: 90px;
  }
  .item-table tbody td {
    padding: 8px 0;
    border-top: 1px solid var(--gray-border);
    vertical-align: top;
    font-size: 0.82rem;
  }
  .item-table tbody td:nth-child(2),
  .item-table tbody td:nth-child(3),
  .item-table tbody td:nth-child(4),
  .item-table tbody td:nth-child(5) {
    text-align: right;
  }
  .item-table .item-name {
    font-weight: 400;
    line-height: 1.4;
    max-width: 360px;
  }
  .item-table .item-name .editable {
    font-size: 0.82rem;
  }
  .item-table .item-qty .editable,
  .item-table .item-cost .editable {
    font-size: 0.82rem;
    text-align: right;
    width: 70px;
    font-variant-numeric: tabular-nums;
  }
  .item-table .item-subtotal {
    font-weight: 500;
    color: var(--black);
    font-variant-numeric: tabular-nums;
  }
  .item-table .row-actions {
    width: 30px;
    text-align: center;
  }
  .item-table .row-actions button {
    background: none;
    border: none;
    color: #ccc;
    cursor: pointer;
    font-size: 1rem;
    padding: 2px 4px;
    border-radius: 3px;
    opacity: 0;
    transition: all 0.15s;
  }
  .item-table tbody tr:hover .row-actions button {
    opacity: 1;
  }
  .item-table .row-actions button:hover {
    color: #e74c3c;
    background: #fee;
  }

  /* Add item row */
  .add-item-row {
    padding: 6px 0;
    text-align: left;
  }
  .add-item-row button {
    background: none;
    border: 1px dashed var(--gray-border);
    color: var(--gray-text);
    padding: 6px 14px;
    cursor: pointer;
    font-size: 0.75rem;
    letter-spacing: 1px;
    border-radius: 4px;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
  }
  .add-item-row button:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: var(--gold-light);
  }

  /* Section subtotal */
  .section-subtotal {
    text-align: right;
    padding: 12px 0;
    border-top: 1px solid var(--gray-border);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 1px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .section-subtotal .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gray-text);
    font-weight: 500;
  }
  .section-subtotal .editable {
    font-weight: 600;
    font-size: 0.85rem;
  }

  /* Grand total */
  .grand-total {
    padding: 24px 48px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 2px solid var(--black);
    margin-top: 16px;
  }
  .grand-total .total-label {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 4px;
  }
  .grand-total .total-amount {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 1px;
  }

  /* Notes */
  .notes-area {
    padding: 16px 48px 32px;
    border-top: 1px solid var(--gray-border);
  }
  .notes-area .field-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gray-text);
    margin-bottom: 8px;
  }
  .notes-area .editable {
    width: 100%;
    min-height: 60px;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--gray-text);
  }

  /* Saved quotes list */
  .saved-panel {
    display: none;
    position: fixed;
    right: 20px;
    top: 60px;
    width: 320px;
    max-height: 80vh;
    background: var(--white);
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    z-index: 200;
    overflow: hidden;
  }
  .saved-panel.open { display: block; }
  .saved-panel-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--gray-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--gray-light);
  }
  .saved-panel-header h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .saved-panel-header button {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--gray-text);
  }
  .saved-list {
    overflow-y: auto;
    max-height: calc(80vh - 56px);
  }
  .saved-item {
    padding: 12px 20px;
    border-bottom: 1px solid var(--gray-border);
    cursor: pointer;
    transition: background 0.15s;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .saved-item:hover {
    background: var(--gold-light);
  }
  .saved-item-info {
    flex: 1;
  }
  .saved-item-name {
    font-size: 0.85rem;
    font-weight: 500;
  }
  .saved-item-date {
    font-size: 0.7rem;
    color: var(--gray-text);
    margin-top: 2px;
  }
  .saved-item-total {
    font-size: 0.85rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--gold);
  }
  .saved-item .delete-quote {
    background: none;
    border: none;
    color: #ccc;
    cursor: pointer;
    margin-left: 8px;
    font-size: 0.9rem;
    padding: 2px 6px;
    border-radius: 3px;
    opacity: 0;
    transition: all 0.15s;
  }
  .saved-item:hover .delete-quote {
    opacity: 1;
  }
  .saved-item .delete-quote:hover {
    color: #e74c3c;
  }
  .saved-empty {
    padding: 40px 20px;
    text-align: center;
    color: var(--gray-text);
    font-size: 0.85rem;
  }

  /* Print styles */
  @media print {
    body { background: white; }
    .toolbar, .add-item-row, .row-actions, .remove-section, .section .remove-section,
    .saved-panel, .no-print { display: none !important; }
    .page-wrapper { padding: 0; }
    .page {
      box-shadow: none;
      max-width: 100%;
      min-height: auto;
    }
    .editable {
      border: none !important;
      background: none !important;
      padding: 2px 0 !important;
    }
    .editable:hover, .editable:focus {
      border: none !important;
      background: none !important;
    }
    .item-table tbody tr:hover {
      background: none;
    }
    .section:hover .remove-section {
      display: none;
    }
    .saved-panel { display: none !important; }
  }

  /* Responsive */
  @media (max-width: 600px) {
    .header-banner { padding: 24px; }
    .header-title { font-size: 2.2rem; }
    .logo-monogram { font-size: 2rem; }
    .client-info { padding: 20px 24px 12px; }
    .section { padding: 0 24px; }
    .grand-total { padding: 16px 24px 24px; }
    .notes-area { padding: 12px 24px 24px; }
    .toolbar-actions button { padding: 6px 10px; font-size: 0.7rem; }
  }
</style>
</head>
<body>

<div class="toolbar">
  <h1>COTIZACIONES</h1>
  <div class="toolbar-actions">
    <button onclick="toggleSavedPanel()">Mis Cotizaciones</button>
    <button class="primary" onclick="saveQuote()">Guardar</button>
    <button onclick="window.print()">Imprimir</button>
    <button onclick="newQuote()">Nueva</button>
    <button class="danger" onclick="clearAll()">Limpiar</button>
  </div>
</div>

<div class="saved-panel" id="savedPanel">
  <div class="saved-panel-header">
    <h3>Mis Cotizaciones</h3>
    <button onclick="toggleSavedPanel()">&times;</button>
  </div>
  <div class="saved-list" id="savedList"></div>
</div>

<div class="page-wrapper">
  <div class="page" id="page">

    <div class="header-banner">
      <div>
        <div class="header-title editable" contenteditable="true" id="docTitle">Cotización</div>
      </div>
      <div class="header-logo">
        <div class="logo-monogram" id="logoMonogram">CC</div>
        <div class="logo-text editable" contenteditable="true" id="companyName">Cristian Castelo</div>
        <div class="logo-subtitle editable" contenteditable="true" id="companySubtitle">diseño floral</div>
      </div>
    </div>

    <div class="client-info">
      <div>
        <div class="field-label">Fecha</div>
        <div class="field-value">
          <span class="editable" contenteditable="true" id="quoteDate">21 Noviembre 2025</span>
        </div>
      </div>
      <div>
        <div class="field-label">Cliente</div>
        <div class="field-value">
          <span class="editable" contenteditable="true" id="clientName">Nombre del Cliente</span>
        </div>
      </div>
      <div>
        <div class="field-label">Evento</div>
        <div class="field-value">
          <span class="editable" contenteditable="true" id="eventName">Tipo de Evento</span>
        </div>
      </div>
    </div>

    <div id="sectionsContainer">
      <!-- Sections will be rendered here -->
    </div>

    <div class="grand-total" id="grandTotal">
      <div class="total-label">TOTAL</div>
      <div class="total-amount" id="totalAmount">$0.00</div>
    </div>

    <div class="notes-area">
      <div class="field-label">Notas / Observaciones</div>
      <div class="editable" contenteditable="true" id="quoteNotes" style="white-space: pre-wrap;"></div>
    </div>

  </div>
</div>

<script>
let quoteId = null;

function getDefaultData() {
  return {
    id: Date.now(),
    title: 'Cotización',
    companyName: 'Cristian Castelo',
    companySubtitle: 'diseño floral',
    logoMonogram: 'CC',
    date: new Date().toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }).toUpperCase(),
    clientName: '',
    eventName: '',
    notes: '',
    sections: [
      {
        id: 1,
        name: 'Sección',
        items: [
          { id: 1, name: '', qty: 1, cost: 0 }
        ]
      }
    ]
  };
}

let quoteData = getDefaultData();
let nextItemId = 100;
let nextSectionId = 100;

function formatCurrency(num) {
  return '$' + Number(num).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function recalculate() {
  let grandTotal = 0;

  document.querySelectorAll('.section').forEach(sectionEl => {
    const sectionId = parseInt(sectionEl.dataset.sectionId);
    const section = quoteData.sections.find(s => s.id === sectionId);
    if (!section) return;

    let sectionTotal = 0;
    sectionEl.querySelectorAll('.item-table tbody tr').forEach(row => {
      const itemId = parseInt(row.dataset.itemId);
      const item = section.items.find(i => i.id === itemId);
      if (!item) return;
      const subtotal = item.qty * item.cost;
      row.querySelector('.item-subtotal').textContent = formatCurrency(subtotal);
      sectionTotal += subtotal;
    });

    const subtotalEl = sectionEl.querySelector('.section-subtotal .subtotal-value');
    if (subtotalEl) subtotalEl.textContent = formatCurrency(sectionTotal);
    grandTotal += sectionTotal;
  });

  document.getElementById('totalAmount').textContent = formatCurrency(grandTotal);
}

function renderSections() {
  const container = document.getElementById('sectionsContainer');
  container.innerHTML = '';
  quoteData.sections.forEach(section => {
    container.appendChild(createSectionElement(section));
  });
  recalculate();
}

function createSectionElement(section) {
  const div = document.createElement('div');
  div.className = 'section';
  div.dataset.sectionId = section.id;

  let itemsHtml = '';
  section.items.forEach(item => {
    itemsHtml += createItemRowHtml(section.id, item);
  });

  div.innerHTML = `
    <div class="section-header">
      <div class="section-title editable" contenteditable="true" 
           onblur="updateSectionName(${section.id}, this.textContent)">${section.name}</div>
      <button class="remove-section no-print" onclick="removeSection(${section.id})">&times;</button>
    </div>
    <table class="item-table">
      <thead>
        <tr>
          <th>Concepto</th>
          <th>Cantidad</th>
          <th>Costo</th>
          <th>Subtotal</th>
          <th class="no-print"></th>
        </tr>
      </thead>
      <tbody>
        ${itemsHtml}
      </tbody>
    </table>
    <div class="add-item-row no-print">
      <button onclick="addItem(${section.id})">+ Agregar concepto</button>
    </div>
    <div class="section-subtotal">
      <span class="label editable" contenteditable="true">Total ${section.name}</span>
      <span class="subtotal-value">${formatCurrency(0)}</span>
    </div>
  `;
  return div;
}

function createItemRowHtml(sectionId, item) {
  return `
    <tr data-item-id="${item.id}">
      <td class="item-name">
        <span class="editable" contenteditable="true" 
              onblur="updateItem(${sectionId}, ${item.id}, 'name', this.textContent)">${item.name}</span>
      </td>
      <td class="item-qty">
        <span class="editable" contenteditable="true"
              onblur="updateItem(${sectionId}, ${item.id}, 'qty', this.textContent)">${item.qty}</span>
      </td>
      <td class="item-cost">
        <span class="editable" contenteditable="true"
              onblur="updateItem(${sectionId}, ${item.id}, 'cost', this.textContent)">${formatCurrency(item.cost)}</span>
      </td>
      <td class="item-subtotal">${formatCurrency(item.qty * item.cost)}</td>
      <td class="row-actions no-print">
        <button onclick="removeItem(${sectionId}, ${item.id})">&times;</button>
      </td>
    </tr>
  `;
}

function updateSectionName(sectionId, name) {
  const section = quoteData.sections.find(s => s.id === sectionId);
  if (section) section.name = name.trim() || 'Sección';
}

function updateItem(sectionId, itemId, field, value) {
  const section = quoteData.sections.find(s => s.id === sectionId);
  if (!section) return;
  const item = section.items.find(i => i.id === itemId);
  if (!item) return;

  if (field === 'name') {
    item.name = value.trim();
  } else if (field === 'qty') {
    item.qty = Math.max(1, parseInt(value.replace(/[^0-9]/g, '')) || 1);
  } else if (field === 'cost') {
    item.cost = Math.max(0, parseFloat(value.replace(/[^0-9.\-]/g, '')) || 0);
  }
  recalculate();
}

function addItem(sectionId) {
  const section = quoteData.sections.find(s => s.id === sectionId);
  if (!section) return;
  const newItem = { id: nextItemId++, name: '', qty: 1, cost: 0 };
  section.items.push(newItem);
  renderSections();
}

function removeItem(sectionId, itemId) {
  const section = quoteData.sections.find(s => s.id === sectionId);
  if (!section) return;
  if (section.items.length <= 1) {
    removeSection(sectionId);
    return;
  }
  section.items = section.items.filter(i => i.id !== itemId);
  renderSections();
}

function addSection() {
  const newSection = {
    id: nextSectionId++,
    name: 'Nueva Sección',
    items: [{ id: nextItemId++, name: '', qty: 1, cost: 0 }]
  };
  quoteData.sections.push(newSection);
  renderSections();
}

function removeSection(sectionId) {
  if (quoteData.sections.length <= 1) return;
  quoteData.sections = quoteData.sections.filter(s => s.id !== sectionId);
  renderSections();
}

function saveQuote() {
  syncEditableFields();
  quoteData.id = quoteId || Date.now();
  quoteId = quoteData.id;

  let quotes = JSON.parse(localStorage.getItem('cotizaciones') || '[]');
  const existing = quotes.findIndex(q => q.id === quoteData.id);
  if (existing >= 0) {
    quotes[existing] = JSON.parse(JSON.stringify(quoteData));
  } else {
    quotes.push(JSON.parse(JSON.stringify(quoteData)));
  }
  localStorage.setItem('cotizaciones', JSON.stringify(quotes));
  renderSavedList();
}

function loadQuote(id) {
  let quotes = JSON.parse(localStorage.getItem('cotizaciones') || '[]');
  const q = quotes.find(q => q.id === id);
  if (!q) return;
  quoteData = JSON.parse(JSON.stringify(q));
  quoteId = q.id;

  document.getElementById('docTitle').textContent = quoteData.title || 'Cotización';
  document.getElementById('companyName').textContent = quoteData.companyName || '';
  document.getElementById('companySubtitle').textContent = quoteData.companySubtitle || '';
  document.getElementById('logoMonogram').textContent = quoteData.logoMonogram || 'CC';
  document.getElementById('quoteDate').textContent = quoteData.date || '';
  document.getElementById('clientName').textContent = quoteData.clientName || '';
  document.getElementById('eventName').textContent = quoteData.eventName || '';
  document.getElementById('quoteNotes').textContent = quoteData.notes || '';

  quoteData.sections.forEach(s => {
    if (s.id >= nextSectionId) nextSectionId = s.id + 1;
    s.items.forEach(i => {
      if (i.id >= nextItemId) nextItemId = i.id + 1;
    });
  });

  renderSections();
  toggleSavedPanel();
}

function deleteQuote(id, e) {
  e.stopPropagation();
  let quotes = JSON.parse(localStorage.getItem('cotizaciones') || '[]');
  quotes = quotes.filter(q => q.id !== id);
  localStorage.setItem('cotizaciones', JSON.stringify(quotes));
  if (quoteId === id) {
    quoteId = null;
  }
  renderSavedList();
}

function syncEditableFields() {
  quoteData.title = document.getElementById('docTitle').textContent.trim();
  quoteData.companyName = document.getElementById('companyName').textContent.trim();
  quoteData.companySubtitle = document.getElementById('companySubtitle').textContent.trim();
  quoteData.logoMonogram = document.getElementById('logoMonogram').textContent.trim();
  quoteData.date = document.getElementById('quoteDate').textContent.trim();
  quoteData.clientName = document.getElementById('clientName').textContent.trim();
  quoteData.eventName = document.getElementById('eventName').textContent.trim();
  quoteData.notes = document.getElementById('quoteNotes').textContent.trim();
}

function renderSavedList() {
  const list = document.getElementById('savedList');
  const quotes = JSON.parse(localStorage.getItem('cotizaciones') || '[]');

  if (quotes.length === 0) {
    list.innerHTML = '<div class="saved-empty">No hay cotizaciones guardadas</div>';
    return;
  }

  list.innerHTML = quotes.map(q => {
    let total = 0;
    q.sections.forEach(s => s.items.forEach(i => total += i.qty * i.cost));
    return `
      <div class="saved-item" onclick="loadQuote(${q.id})">
        <div class="saved-item-info">
          <div class="saved-item-name">${q.clientName || 'Sin cliente'}</div>
          <div class="saved-item-date">${q.date || ''}</div>
        </div>
        <div class="saved-item-total">${formatCurrency(total)}</div>
        <button class="delete-quote" onclick="deleteQuote(${q.id}, event)">&times;</button>
      </div>
    `;
  }).join('');
}

function toggleSavedPanel() {
  const panel = document.getElementById('savedPanel');
  panel.classList.toggle('open');
  if (panel.classList.contains('open')) renderSavedList();
}

function newQuote() {
  if (confirm('¿Crear nueva cotización? Se perderán los cambios no guardados.')) {
    quoteData = getDefaultData();
    quoteId = null;
    nextItemId = 100;
    nextSectionId = 100;

    document.getElementById('docTitle').textContent = quoteData.title;
    document.getElementById('companyName').textContent = quoteData.companyName;
    document.getElementById('companySubtitle').textContent = quoteData.companySubtitle;
    document.getElementById('logoMonogram').textContent = quoteData.logoMonogram;
    document.getElementById('quoteDate').textContent = quoteData.date;
    document.getElementById('clientName').textContent = '';
    document.getElementById('eventName').textContent = '';
    document.getElementById('quoteNotes').textContent = '';

    renderSections();
  }
}

function clearAll() {
  if (confirm('¿Limpiar todo? Esta acción no se puede deshacer.')) {
    quoteData = getDefaultData();
    quoteId = null;
    nextItemId = 100;
    nextSectionId = 100;
    localStorage.removeItem('cotizaciones');

    document.getElementById('docTitle').textContent = quoteData.title;
    document.getElementById('companyName').textContent = quoteData.companyName;
    document.getElementById('companySubtitle').textContent = quoteData.companySubtitle;
    document.getElementById('logoMonogram').textContent = quoteData.logoMonogram;
    document.getElementById('quoteDate').textContent = quoteData.date;
    document.getElementById('clientName').textContent = '';
    document.getElementById('eventName').textContent = '';
    document.getElementById('quoteNotes').textContent = '';

    renderSections();
    renderSavedList();
  }
}

// Close saved panel when clicking outside
document.addEventListener('click', (e) => {
  const panel = document.getElementById('savedPanel');
  if (panel.classList.contains('open') && !panel.contains(e.target) && 
      !e.target.closest('.toolbar-actions button')) {
    panel.classList.remove('open');
  }
});

// Add "add section" button
document.addEventListener('DOMContentLoaded', () => {
  const wrapper = document.querySelector('.page-wrapper .page');
  const addSectionBtn = document.createElement('div');
  addSectionBtn.className = 'add-item-row no-print';
  addSectionBtn.style.padding = '0 48px';
  addSectionBtn.innerHTML = '<button onclick="addSection()">+ Agregar sección</button>';
  wrapper.insertBefore(addSectionBtn, document.getElementById('grandTotal'));

  renderSections();
  renderSavedList();
});
</script>

</body>
</html>
